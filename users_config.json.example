{
  "users": {
    "ExampleUser": {
      "profile": {
        "first_name": "Firstname",
        "last_name": "Lastname",
        "email": "example@email.com",
        "phone": "+91 9999999999",
        "experience": "5+ years",
        "current_location": "Bangalore, India",
        "preferred_locations": "Bangalore, India",
        "linkedin_url": "https://www.linkedin.com/in/username",
        "resume_url": "https://example.com/resume.pdf",
        "resume_name": "Resume.pdf",
        "current_ctc": "15 LPA",
        "expected_ctc": "25 LPA"
      },
      "email_scraper": {
        "sender_email": "example@email.com",
        "interval": "60",
        "review_mode": true,
        "keywords": [
          "Developer",
          "Engineer"
        ],
        "email_template": "Hi {FIRST_NAME},\n\nI am applying for a position...\n\nRegards,\n{FIRST_NAME}"
      },
      "linkedin_connect": {
        "interval": "120",
        "review_mode": true,
        "keywords": [
          "Recruiter",
          "Hiring Manager"
        ],
        "message_template": "Hi, I am {FIRST_NAME}. Would you kindly refer me?\nJob: {job_url}"
      }
    }
  },
  "selected_user": "ExampleUser",
  "global_settings": {
    "linkedin_email": "linkedin.user@example.com",
    "linkedin_password": "YOUR_LINKEDIN_PASSWORD",
    "search_location": "Bangalore, India",
    "search_time_range": "r604800",
    "dry_run": "0",
    "max_apply": "5",
    "max_run_duration_seconds": "120",
    "smtp_server": "smtp.gmail.com",
    "smtp_port": "587",
    "smtp_email": "smtp.user@example.com",
    "smtp_password": "YOUR_SMTP_PASSWORD"
  }
}
