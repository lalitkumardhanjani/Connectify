# LinkedIn automation environment configuration
# Copy this file to .env and update values as needed.

LINKEDIN_EMAIL=your.email@example.com
LINKEDIN_PASSWORD=your_linkedin_password
SEARCH_KEYWORDS=SQL Server DBA
SEARCH_LOCATION=Bangalore, Karnataka, India
SEARCH_TIME_RANGE=r604800
DRY_RUN=1
MAX_RUN_DURATION_SECONDS=600
CHROME_PROFILE_DIR=.chrome-profile

# Optional: Path to custom Google Chrome binary (useful if Edge is hijacked as the default chrome command)
# CHROME_BINARY_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
